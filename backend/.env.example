# ─────────────────────────────────────────────────────────────────────────────
# LinkedIn AI Bot — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to GitHub. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic (Claude) — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Hugging Face — get from huggingface.co > Settings > Access Tokens
HF_API_KEY=hf_your-key-here

# LinkedIn — get from developer.linkedin.com (see guide Step 4)
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token-here
LINKEDIN_PERSON_ID=your-linkedin-person-id-here

# Server port (leave as 3001 unless you have a conflict)
PORT=3001
